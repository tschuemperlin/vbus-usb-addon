{
  "name": "VBus USB Reader",
  "version": "1.0.2",
  "slug": "vbus_usb",
  "description": "Reads Resol VBus data from USB and publishes via MQTT",
  "arch": ["aarch64"],
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "options": {
    "device": "/dev/ttyUSB0",
    "baudrate": 9600,
    "mqtt_host": "homeassistant",
    "mqtt_port": 1883,
    "mqtt_user": "",
    "mqtt_pass": ""
  },
  "schema": {
    "device": "str",
    "baudrate": "int",
    "mqtt_host": "str",
    "mqtt_port": "int",
    "mqtt_user": "str",
    "mqtt_pass": "str"
  }
}
